<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#6688888E">
    <item>
        <layer-list>
            <!-- Brushed chrome base -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:endColor="#FF6B6F78"
                        android:startColor="#FFD8DEE6"
                        android:type="linear" />
                    <corners android:radius="8dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF4A4D54" />
                </shape>
            </item>
            <!-- Upper highlight gloss -->
            <item
                android:bottom="3dp"
                android:left="2dp"
                android:right="2dp"
                android:top="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:endColor="#00FFFFFF"
                        android:startColor="#55FFFFFF"
                        android:type="linear" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
