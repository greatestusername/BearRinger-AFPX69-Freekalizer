<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Freekalizer" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_app</item>
        <item name="android:colorBackground">@color/background_app</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="colorPrimary">@color/accent_led_cyan</item>
        <item name="colorAccent">@color/accent_led_cyan</item>
    </style>

    <!-- Use platform TextView parent; invalid parent names break inflation on some devices. -->
    <style name="Widget.Freekalizer.SectionTitle" parent="@android:style/Widget.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
</resources>

