<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="8dp"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Zone: TOP_STATUS_AND_MASTER -->
        <TextView
            style="@style/Widget.Freekalizer.SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zone_top_status" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_zone_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/permission_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                tools:text="Mic permission: GRANTED" />

            <Button
                android:id="@+id/request_mic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_zone"
                android:text="@string/grant_mic"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:labelFor="@id/input_spinner"
                android:text="@string/label_input_device"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/input_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:popupBackground="@color/surface_zone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:labelFor="@id/output_spinner"
                android:text="@string/label_output_device"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/output_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:popupBackground="@color/surface_zone" />

            <TextView
                android:id="@+id/route_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                tools:text="Selected input id: default" />

            <TextView
                android:id="@+id/meter_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                tools:text="IN LEVEL: 0%  OVERLOAD IN: NO" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/placeholder_bpm"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/placeholder_master_pitch"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/start_monitoring"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:text="@string/start_monitoring"
                    android:textColor="@color/accent_led_cyan" />

                <Button
                    android:id="@+id/stop_monitoring"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:text="@string/stop_monitoring"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Zone: SAMPLER_TRANSPORT_AND_ROUTING -->
        <TextView
            style="@style/Widget.Freekalizer.SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zone_sampler" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_zone_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_rec_length_quantized"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/bar_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:popupBackground="@color/surface_zone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_free_rec_cap"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/free_cap_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:popupBackground="@color/surface_zone" />

            <TextView
                android:id="@+id/recording_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                tools:text="REC: OFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/rec_quantized"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:text="@string/rec_quantized"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/rec_free"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:text="@string/rec_free"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <Button
                android:id="@+id/rec_free_stop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_zone"
                android:text="@string/end_free_rec"
                android:textColor="@color/text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/play_stop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:text="@string/play_stop"
                    android:textColor="@color/accent_led_cyan" />

                <ToggleButton
                    android:id="@+id/fx_route_toggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:textColor="@color/text_primary"
                    android:textOff="@string/fx_route_off"
                    android:textOn="@string/fx_route_on" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/placeholder_sample_pitch"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/shot_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_button_zone"
                android:text="@string/shot_hold"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />

            <ToggleButton
                android:id="@+id/rev_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_zone"
                android:textColor="@color/text_primary"
                android:textOff="@string/rev_off"
                android:textOn="@string/rev_on" />
        </LinearLayout>

        <!-- Zone: EQ_AND_KILL -->
        <TextView
            style="@style/Widget.Freekalizer.SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zone_eq" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_zone_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/eq_low"
                    android:textColor="@color/text_muted" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/eq_mid"
                    android:textColor="@color/text_muted" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/eq_high"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_zone"
                android:enabled="false"
                android:text="@string/eq_kill"
                android:textColor="@color/text_muted" />
        </LinearLayout>

        <!-- Zone: PERFORMANCE_SURFACE -->
        <TextView
            style="@style/Widget.Freekalizer.SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zone_performance" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_zone_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="120dp"
                android:text="@string/placeholder_scratch"
                android:textColor="@color/text_muted"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/fx_filter"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/fx_flanger"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/fx_delay"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_zone"
                    android:enabled="false"
                    android:text="@string/fx_mix"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
